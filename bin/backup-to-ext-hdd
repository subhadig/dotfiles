DEVICE_LABEL='TOSHIBA EXT'
MOUNT_PATH="/mnt"

# List of top level directories under home that need to be backed up
# Paths are relative from the user's home directory
INCLUDE_DIRS=('Documents' 'Music' 'Pictures' 'Videos')


echo Initiating backup...

if ! command -v rsync 1>/dev/null; then
    echo rsync is not available. Exiting...
    exit 1
fi

# Find the pretty hostname
comp_name=`hostnamectl --static`

if [ -z "$comp_name" ]; then
    echo "Computer name not set. Exiting."
    exit 1
fi

read -p "Type the computer name[$comp_name] to be used for backup: " comp_name_user

if [ "$comp_name_user" != "$comp_name" ]; then
    echo Computer name did not match. Exiting.
    exit 1
fi

USER_HAS_SUDO=false
sudo -v 2>/dev/null
if [ $? -eq 0 ]; then
    USER_HAS_SUDO=true
fi

exec_admin_command() {
    if $USER_HAS_SUDO; then
        sudo $1
    else
        su -c "$1"
    fi
}


# Get the device path with the matching label
DEVICE_PATH=''
IFS_ORIG=$IFS
IFS='\n'
while read line
do
 label=`cut -f2- -d' ' <<< "${line}"`
 if [ "$label" = "$DEVICE_LABEL" ]; then
     DEVICE_PATH=`cut -f1 -d' ' <<< "${line}"`
     break
 fi
done <<<`lsblk -f -o NAME,LABEL -l -n -p`
IFS=$IFS_ORIG

if [ -z "$DEVICE_PATH" ]; then
    echo "Device path not found. Exiting"
    exit 1
fi

# Mount the external drive
read -p "Mounting ${DEVICE_PATH} to ${MOUNT_PATH}. Continue? [y/N] " choice
if [ "$choice" != "y" ]; then
    echo Selected $choice. Exiting.
    exit 1
fi

# Create the mount path if not exists
if [ ! -d "${MOUNT_PATH}" ]; then
    echo Path ${MOUNT_PATH} does not exists. Creating..
    exec_admin_command "mkdir -p \"${MOUNT_PATH}\""
fi

echo Mounting...
exec_admin_command "mount -o uid=${USER} -t ntfs \"${DEVICE_PATH}\" \"${MOUNT_PATH}\""


# Unmount the external drive
unmount() {
    echo Unmounting ${DEVICE_PATH}...
    exec_admin_command "umount \"${DEVICE_PATH}\""
}

trap unmount EXIT

echo

OPTS="-ai --delay-updates --delete"
SRC_ROOT="$HOME"
DEST="${MOUNT_PATH}/${comp_name}"
LOGFILE="$DEST/logs/`date +%Y-%m-%d`.log"

# Create the required dest directories
mkdir -p "$DEST/latest"
mkdir -p "$DEST/logs"

# Sync every path in synced_dir
for dir in "${INCLUDE_DIRS[@]}"
do
    SRC="$SRC_ROOT/$dir"
    if [ -d "$SRC" ]; then
        echo Syncing $SRC to $DEST/latest...
        rsync $OPTS "$SRC" "$DEST/latest" >>$LOGFILE
    else
        echo WARNING: Non-existent source directory: $SRC
    fi
    echo
done

COUNT=`wc -l $LOGFILE | cut -d ' ' -f 1`
echo $COUNT
if [ $COUNT -ne 0 ]; then
    DATETAG=`date +%Y-%m-%d`
    if [ ! -e "$DEST/$DATETAG" ]; then
        echo Creating snapshot: $DATETAG
        cp -al "$DEST/latest" "$DEST/$DATETAG"
    else
        echo Snapshot already exists: $DATETAG. Skipping...
    fi
fi
